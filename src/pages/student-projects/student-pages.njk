---
layout: base
pagination:
  data: student
  size: 1
  alias: student
  addAllPagesToCollections: true
permalink: "student-projects/{{ student.title | slugify }}/"
eleventyNavigation:
  key: studentproject
  title: {{ student.title }}
  parent: student
---

<div class="hero full-width">
{% if student.heroImage.src %}
{% heroimage student.heroImage.src, student.heroImage.alt, "full-width hero__img" %}
{% endif %}
  <div class="hero__content">
    <h1>{{ student.title }}</h1>
  </div>
</div>



{% if student.video.videoId %}
  <h2>{{student.video.type}}</h2>
  <iframe width="900" height="506" src="https://www.youtube-nocookie.com/embed/{{student.video.videoId}}" title="{{student.video.description}}" frameborder="0" allow="encrypted-media;" referrerpolicy="strict-origin-when-cross-origin" allowfullscreen></iframe>
{% endif %}


{% if student.aboutGame %}
  <h2>About the Game</h2>
  {% for item in student.aboutGame %}
  <p>{{item | safe}}</p>
  {% endfor %}
{% endif %}


{% if student.onepager.src %}
<div class="onepager breakout flow">
<h2>{{ student.onepager.title }}</h2>
{% image student.onepager.src, student.onepager.alt, "onepager__img" %}
</div>
{% endif %}

{% if student.story %}
  <h2>Story</h2>
  {% for item in student.story %}
  <p>{{item | safe}}</p>
  {% endfor %}
{% endif %}

{% if student.responsibilities %}
  <h2>Responsibilities</h2>

  <div class="breakout flow flow-80 skills">
    {% for item in student.responsibilities %}
      <div class="two-column{% if loop.index % 2 == 0 %} two-column--swapped{% endif %}">

        <div class="two-column__one flow prose">
          <h3>{{item.role}}</h3>
          {% for part in item.description %}
          <p>{{part | safe }}</p>
          {% endfor %}

          {% if item.list %}
          <ul class="">
            {% for part in item.list %}
            <li>{{part | safe}}</li>
            {% endfor %}
          </ul>
          {% endif%}
        </div>


        <div class="two-column__two flow">
          {% if item.image %}
          <div class="skill__img-wrapper">
            {% image item.image.src, item.image.alt, "skill__img" %}
          </div>
          {% endif%}

          {% if item.skillGallery[0].src %}
            <div id="splide-skillGallery-{{ loop.index }}" class="splide" role="group" aria-label="Image gallery">
              <div class="splide__track">
                <ul class="splide__list">
                  {% for img in item.skillGallery %}
                  <li class="splide__slide">
                    {% image img.src, img.alt %}
                  </li>
                  {% endfor %}
                </ul>
              </div>
            </div>
          {% endif %}
        </div>

      </div>

    {% endfor %}
  </div>

{% endif %}


{% if student.gallery[0].src %}
  <section id="splide-gallery" class="splide breakout flow" aria-labelledby="carousel-heading">
    <h2 id="carousel-heading" class="visuallyhidden">Project Images</h2>

    <div class="splide__track">
      <ul class="splide__list">
        {% for item in student.gallery %}
        <li class="splide__slide">
          {% image item.src, item.alt, "gallery__img" %}
        </li>
        {% endfor %}
      </ul>
    </div>
  </section>
{% endif %}


<script>
  document.addEventListener( 'DOMContentLoaded', function() {
    const galleries = document.querySelectorAll('.splide');
    galleries.forEach(slide => {
      let splide = new Splide(`#${slide.id}`, {
        type  : 'fade',
        rewind: true,
        padding: '3rem',
        gap:'2rem',
        lazyLoad: 'nearby',
      });
      splide.mount();
    });
  } );
</script>

<script defer src="/assets/vendor/splide-4.1.3/dist/js/splide.min.js"></script>
