
{% set currentUrl = page.url %}

<ul class="project-teaser student breakout">
    {% for page in student %}
    <li>
        <a href="/student-projects/{{ page.title | slugify }}" {{ 'aria-current=page' if currentUrl === page.url }} class="project-teaser__link text-accent-bold">
            {{ page.title }}
        </a>
    </li>
    {% endfor %}
</ul>
